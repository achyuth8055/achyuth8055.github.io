# Docker
.dockerignore
**/node_modules
**/dist
**/.git
**/.vscode
**/coverage
**/.env.local

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pycache__/
*.py[cod]
*$py.class

# Environment
.env.local
.env.*.local

# OS
.DS_Store
Thumbs.db

# IDE
.vscode
.idea
*.swp
*.swo
*~

# Build outputs
dist/
build/
*.egg-info/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
venv/
env/
.Python
*.so
*.egg
*.egg-info/
.pytest_cache/
.coverage

# Node
node_modules/
.npm
.yarn
package-lock.json

# Uploads and temp files
uploads/*
converted/*
outputs/*
!uploads/.gitkeep
!converted/.gitkeep
!outputs/.gitkeep

# Backend specific
backend/__pycache__/
backend/*.log
backend/backend.log
backend/nohup.out

# Test files (keep scripts but not generated files)
test_files/test_*.pdf
test_files/test_*.jpg
test_files/test_*.zip
test_files/test_*.png
!test_files/test_sample.pdf

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Temporary files
*.tmp
*.bak
*.swp
*~
