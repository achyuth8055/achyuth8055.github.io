# Centralized Configuration
# Used by services and orchestration

# Service Base URLs (internal Docker network)
IMAGE_BASE=http://image:5004
PDFDOCX_BASE=http://pdfdocx:8080
CONVERTER_BASE=http://gotenberg:3000
PROTOOLS_BASE=http://stirling:8080

# Public Base (gateway)
PUBLIC_BASE=http://localhost

# Service Ports
IMAGE_PORT=5004
PDFDOCX_PORT=8080
CONVERTER_PORT=3000
PROTOOLS_PORT=8080
GATEWAY_PORT=80

# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=0
SECRET_KEY=change-me-in-production-to-random-secret

# Upload Limits
MAX_CONTENT_LENGTH=52428800
MAX_FILE_SIZE=52428800

# Optional: Real-ESRGAN and Background Removal
ENABLE_REALESRGAN=false
ENABLE_INSPYRENET=false
