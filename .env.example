# Centralized Configuration - Copy to .env and customize

# ===== Service Base URLs (Internal Docker Network) =====
IMAGE_BASE=http://image:5004
PDFDOCX_BASE=http://pdfdocx:8080
CONVERTER_BASE=http://gotenberg:3000   # Document converter service
PROTOOLS_BASE=http://stirling:8080    # PDF tools service

# ===== Public Configuration =====
PUBLIC_BASE=http://localhost

# ===== Service Ports =====
IMAGE_PORT=5004
PDFDOCX_PORT=8080
CONVERTER_PORT=3000
PROTOOLS_PORT=8080
GATEWAY_PORT=80

# ===== Flask Configuration =====
FLASK_ENV=production
FLASK_DEBUG=0
SECRET_KEY=CHANGE_ME_TO_RANDOM_SECRET_IN_PRODUCTION

# ===== Upload Limits (in bytes) =====
# 50MB default
MAX_CONTENT_LENGTH=52428800
MAX_FILE_SIZE=52428800

# ===== Optional: AI Features =====
# Enable Real-ESRGAN for image upscaling (requires model file)
ENABLE_REALESRGAN=false

# Enable InSPyReNet for background removal (requires model file)
ENABLE_INSPYRENET=false

# ===== Security (Production) =====
# Enable these in production
# CORS_ORIGINS=https://yourdomain.com
# SECURE_COOKIES=true
# SESSION_COOKIE_SECURE=true

# ===== Google Analytics =====
GA_TRACKING_ID=G-PHNX522MM7

# ===== Monitoring =====
# LOG_LEVEL=INFO
# SENTRY_DSN=your-sentry-dsn-here
